{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "OTel Collector prometheus exporter를 Prometheus가 scrape합니다.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "forge-glow — Claude Code Efficiency",
  "uid": "forge-glow-efficiency",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "tags": ["claude-code", "otel", "cost", "forge-glow"],
  "templating": {
    "list": [
      {
        "name": "model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(claude_code_api_request_total, model)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "모델별 누적 비용 (USD)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (model) (rate(claude_code_api_request_cost_usd_total{model=~\"$model\"}[5m]))",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "캐시 히트율",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(claude_code_api_request_cache_read_tokens_total[5m])) / sum(rate(claude_code_api_request_input_tokens_total[5m]) + rate(claude_code_api_request_cache_read_tokens_total[5m])) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 70 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "평균 응답 시간 (ms)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(claude_code_api_request_duration_ms_sum[5m])) / sum(rate(claude_code_api_request_duration_ms_count[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 15000 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "도구 호출 성공률 (claude_code.tool_result)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (tool_name) (rate(claude_code_tool_result_total{success=\"true\"}[5m])) / sum by (tool_name) (rate(claude_code_tool_result_total[5m])) * 100",
          "legendFormat": "{{tool_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "모델별 토큰 사용량 (24h)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (model) (increase(claude_code_api_request_output_tokens_total{model=~\"$model\"}[24h]))",
          "legendFormat": "{{model}} output"
        },
        {
          "expr": "sum by (model) (increase(claude_code_api_request_input_tokens_total{model=~\"$model\"}[24h]))",
          "legendFormat": "{{model}} input"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "forge-glow alerts",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "ALERTS{alertname=~\"ForgeGlow.*\"}",
        "iconColor": "red",
        "enable": true
      }
    ]
  }
}
